// This is your Prisma schema file

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  USER
  ADMIN
}

enum AuthProvider {
  GOOGLE
  GITHUB
}

enum JobType {
  EMAIL
  WEBHOOK
  REMINDER
  REPORT
  CLEANUP
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum WorkerStatus {
  ACTIVE
  OFFLINE
}

enum NotificationChannelType {
  EMAIL
  SMS
  WEBHOOK
  IN_APP
}

enum NotificationEventType {
  REMINDER
  JOB_COMPLETED
  JOB_FAILED
  JOB_RETRYING
  SYSTEM
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id                    String   @id @default(uuid())

  email                 String   @unique

  firstName             String?

  lastName              String?

  clerkId               String   @unique

  imageUrl              String?

  role                  UserRole @default(USER)

  createdAt             DateTime @default(now())

  updatedAt             DateTime @updatedAt

  accounts              Account[]

  jobs                  Job[]

  auditLogs             AuditLog[]

  notificationChannels  NotificationChannel[]

  notifications         Notification[]

  @@index([email])
}

//////////////////////////////////////////////////////
// ACCOUNT
//////////////////////////////////////////////////////

model Account {
  id                  String @id @default(uuid())

  userId              String

  user                User @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider            AuthProvider

  providerAccountId   String

  createdAt           DateTime @default(now())

  @@unique([provider, providerAccountId])

  @@index([userId])
}

//////////////////////////////////////////////////////
// JOB
//////////////////////////////////////////////////////

model Job {
  id                  String @id @default(uuid())

  name                String

  description         String?

  type                JobType

  status              JobStatus @default(PENDING)

  priority            JobPriority @default(NORMAL)

  queueName           String

  payload             Json?

  isRecurring         Boolean @default(false)

  cronExpression      String?

  scheduledAt         DateTime?

  nextRunAt           DateTime?

  lastRunAt           DateTime?

  maxRetries          Int @default(3)

  retryDelaySeconds   Int @default(60)

  idempotencyKey      String? @unique

  deadLettered        Boolean @default(false)

  createdById         String

  createdBy           User @relation(fields: [createdById], references: [id])

  executions          JobExecution[]

  notifications       Notification[]

  createdAt           DateTime @default(now())

  updatedAt           DateTime @updatedAt

  @@index([status])

  @@index([type])

  @@index([priority])

  @@index([createdById])

  @@index([scheduledAt])

  @@index([nextRunAt])

  @@index([queueName])
}

//////////////////////////////////////////////////////
// JOB EXECUTION
//////////////////////////////////////////////////////

model JobExecution {
  id                String @id @default(uuid())

  jobId             String

  job               Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  status            ExecutionStatus

  attempt           Int @default(1)

  bullJobId         String?

  workerId          String?

  worker            Worker? @relation(fields: [workerId], references: [id])

  startedAt         DateTime?

  finishedAt        DateTime?

  durationMs        Int?

  errorMessage      String?

  result            Json?

  createdAt         DateTime @default(now())

  @@index([jobId])

  @@index([status])

  @@index([workerId])

  @@index([createdAt])

  @@index([bullJobId])
}

//////////////////////////////////////////////////////
// WORKER
//////////////////////////////////////////////////////

model Worker {
  id                String @id @default(uuid())

  name              String

  hostname          String?

  pid               Int?

  status            WorkerStatus @default(ACTIVE)

  jobsProcessed     Int @default(0)

  lastHeartbeat     DateTime?

  startedAt         DateTime @default(now())

  executions        JobExecution[]

  @@index([status])

  @@index([lastHeartbeat])
}

//////////////////////////////////////////////////////
// NOTIFICATION CHANNEL
//////////////////////////////////////////////////////

model NotificationChannel {
  id              String @id @default(uuid())

  userId          String

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String

  type            NotificationChannelType

  destination     String

  enabled         Boolean @default(true)

  createdAt       DateTime @default(now())

  @@unique([userId, destination, type])

  @@index([userId])
}

model Notification {
  id          String @id @default(uuid())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId       String?
  job         Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  title       String
  message     String

  type        NotificationEventType

  isRead      Boolean @default(false)

  metadata    Json?

  createdAt   DateTime @default(now())
  readAt      DateTime?

  @@index([userId])
  @@index([jobId])
  @@index([userId, isRead])
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id              String @id @default(uuid())

  userId          String?

  user            User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  action          String

  entityType      String

  entityId        String

  actorType       String?

  metadata        Json?

  createdAt       DateTime @default(now())

  @@index([userId])

  @@index([entityType])

  @@index([entityId])

  @@index([createdAt])
}